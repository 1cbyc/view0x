COMPOSE_PROJECT_NAME=view0x

# ========== Host Ports ==========
WEB_PORT=8088
API_PORT=3001
POSTGRES_PORT=5433
REDIS_PORT=6380

# ========== Database Configuration ==========
POSTGRES_DB=view0x_db
POSTGRES_USER=view0x_user
POSTGRES_PASSWORD=replace_with_a_secure_database_password
DATABASE_URL=postgresql://view0x_user:replace_with_a_secure_database_password@postgres:5432/view0x_db

# ========== Redis Configuration ==========
REDIS_URL=redis://redis:6379

# ========== Backend Configuration ==========
NODE_ENV=production
PORT=3001
API_VERSION=v1
JWT_SECRET=replace_with_a_secure_random_string_of_at_least_32_characters
REFRESH_TOKEN_SECRET=replace_with_another_secure_random_string_of_at_least_32_characters
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_EXPIRES_IN=7d
CORS_ORIGINS=http://localhost:8088,http://127.0.0.1:8088,http://localhost:3001,http://127.0.0.1:3001

# ========== Analysis Configuration ==========
PYTHON_API_URL=http://python-worker:8000
SLITHER_TIMEOUT=300
MAX_CONTRACT_SIZE=1048576
MAX_CONCURRENT_ANALYSES=3
ANALYSIS_ENGINE=python

# ========== Frontend Build Configuration ==========
VITE_API_URL=/api
VITE_SOCKET_URL=/
VITE_APP_TITLE=view0x - Smart Contract Analysis
VITE_APP_DESCRIPTION=Analyze your Solidity smart contracts for vulnerabilities, gas optimizations, and code quality issues

# ========== App Limits / Logging ==========
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX_REQUESTS=1000
MAX_FILE_SIZE=1048576
UPLOAD_DIR=./uploads
BCRYPT_ROUNDS=12
LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# ========== Optional External Services ==========
MYTHX_API_KEY=
ETHERSCAN_API_KEY=

# ========== Email Configuration (Optional) ==========
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=
