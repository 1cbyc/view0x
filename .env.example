COMPOSE_PROJECT_NAME=view0x

# ========== Host Ports ==========
WEB_PORT=18088
API_PORT=18091
POSTGRES_PORT=15433
REDIS_PORT=16380

# ========== Database Configuration ==========
POSTGRES_DB=view0x_db
POSTGRES_USER=view0x_user
POSTGRES_PASSWORD=replace_with_a_secure_database_password
DATABASE_URL=postgresql://view0x_user:replace_with_a_secure_database_password@postgres:5432/view0x_db

# ========== Redis Configuration ==========
REDIS_URL=redis://redis:6379

# ========== Backend Configuration ==========
NODE_ENV=production
PORT=3001
API_VERSION=v1
JWT_SECRET=replace_with_a_secure_random_string_of_at_least_32_characters
REFRESH_TOKEN_SECRET=replace_with_another_secure_random_string_of_at_least_32_characters
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_EXPIRES_IN=7d
CORS_ORIGINS=http://localhost:18088,http://127.0.0.1:18088,http://localhost:18091,http://127.0.0.1:18091

# ========== Analysis Configuration ==========
PYTHON_API_URL=http://python-worker:8000
SLITHER_TIMEOUT=300
MAX_CONTRACT_SIZE=1048576
MAX_CONCURRENT_ANALYSES=3
ANALYSIS_ENGINE=python

# ========== Frontend Build Configuration ==========
# Docker/same-origin: /api ; socket empty = current host. Production: use API domain, never bare IP.
# Cloudflare Pages example: VITE_API_URL=https://api.view0x.com/api  VITE_SOCKET_URL=https://api.view0x.com
VITE_API_URL=/api
VITE_SOCKET_URL=
VITE_APP_TITLE=view0x - Smart Contract Analysis
VITE_APP_DESCRIPTION=Analyze your Solidity smart contracts for vulnerabilities, gas optimizations, and code quality issues

# ========== App Limits / Logging ==========
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX_REQUESTS=1000
MAX_FILE_SIZE=1048576
UPLOAD_DIR=./uploads
BCRYPT_ROUNDS=12
LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# ========== Cloudflare Tunnel (optional — view0x-only HTTPS, no koreshield Caddy) ==========
# CLOUDFLARE_TUNNEL_TOKEN=

# ========== Optional External Services ==========
MYTHX_API_KEY=
ETHERSCAN_API_KEY=

# ========== Email (free tier: Brevo — https://www.brevo.com) ==========
# Cloudflare Email Routing is receive-only; use Brevo/Resend to SEND from the app.
APP_PUBLIC_URL=https://view0x.com
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-brevo-login-email
SMTP_PASS=your-brevo-smtp-key
FROM_EMAIL=noreply@view0x.com
