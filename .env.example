# View0x Environment Configuration
# Copy this file to .env and update all values

# ========== Database Configuration ==========
POSTGRES_DB=view0x_db
POSTGRES_USER=view0x_user
POSTGRES_PASSWORD=change_this_secure_password

# ========== Backend Configuration ==========
NODE_ENV=production
APP_PORT=8088
PORT=4000
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
REDIS_URL=redis://redis:6379

# JWT Secrets (generate secure random strings)
JWT_SECRET=generate_secure_random_string_min_32_chars
REFRESH_TOKEN_SECRET=generate_another_secure_random_string_min_32_chars

# CORS Origins (comma-separated)
CORS_ORIGINS=https://yourdomain.com,http://localhost:3000

# Analysis Configuration
PYTHON_API_URL=http://python-worker:8000
SLITHER_TIMEOUT=300
MAX_CONTRACT_SIZE=1048576
MAX_CONCURRENT_ANALYSES=3

# ========== Frontend Configuration ==========
VITE_API_URL=http://localhost:4000/api
VITE_SOCKET_URL=http://localhost:4000
VITE_APP_TITLE=view0x - Smart Contract Analysis
VITE_APP_DESCRIPTION=Analyze your Solidity smart contracts for vulnerabilities, gas optimizations, and code quality issues

# ========== Optional External Services ==========
# MYTHX_API_KEY=your_mythx_api_key_here
# ETHERSCAN_API_KEY=your_etherscan_api_key_here

# ========== Email Configuration (Optional) ==========
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
# FROM_EMAIL=noreply@yourdomain.com
